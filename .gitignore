# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# SENSITIVE FILES - NEVER PUSH
# ==========================================

# Environment variables (contains API keys, secrets)
.env
.env.local
.env.*.local
backend/.env
# Keep .env.example files (they have placeholders, not real secrets)
!.env.example
!backend/.env.example

# ==========================================
# LARGE FILES - NOT RECOMMENDED
# ==========================================

# Dataset (training images - very large)
Dataset/

# ML Model files (large binary files)
backend/ml/models/*.keras
backend/ml/models/*.h5
backend/ml/models/*.pkl
backend/ml/models/logs/

# Generated images/charts
backend/ml/models/*.png
backend/ml/models/paper_figures/

# ==========================================
# PYTHON
# ==========================================

# Virtual environment
backend/venv/
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ==========================================
# NODE.JS
# ==========================================

node_modules
dist
dist-ssr
*.local

# ==========================================
# EDITOR/IDE
# ==========================================

.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# OS FILES
# ==========================================

Thumbs.db
.DS_Store
